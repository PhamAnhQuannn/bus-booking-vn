generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

/// Issue 045: operator approval lifecycle. `status` is the CANONICAL state.
/// SUSPENDED is the canonical "frozen" state; the pre-existing `disabledAt`
/// column is kept for back-compat and is now SYNCED to status by the transition
/// service (SUSPENDED → disabledAt=now(); APPROVED → disabledAt cleared).
enum OperatorStatus {
  PENDING_REVIEW
  UNDER_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
}

model Operator {
  id                 String                  @id @default(cuid())
  legalName          String
  contactPhone       String
  contactEmail       String
  notificationPhone  String?
  /// Issue 045: canonical approval state. Defaults to PENDING_REVIEW for new
  /// applicants. Only APPROVED operators are search-visible / bookable (S05).
  status             OperatorStatus          @default(PENDING_REVIEW)
  /// Issue 045: rejection reason set when status → REJECTED (shown on resubmit).
  rejectionReason    String?
  /// Issue 045: back-compat freeze flag, kept in sync with status by the
  /// transition service. `status` is canonical; SUSPENDED is the canonical
  /// suspend. disabledAt is NOT the source of truth — read `status`.
  disabledAt         DateTime?
  createdAt          DateTime                @default(now())
  buses              Bus[]
  operatorUsers      OperatorUser[]
  routes             Route[]
  trips              Trip[]
  recurringTemplates RecurringTripTemplate[]
  payouts            Payout[]
  ledgerEntries      LedgerEntry[]
  feeConfigs         FeeConfig[]

  @@index([id])
  @@index([status])
}

enum BusType {
  coach
  sleeper
  limousine
}

model Bus {
  id                 String                  @id @default(cuid())
  operatorId         String
  capacity           Int
  licensePlate       String
  busType            BusType
  deactivatedAt      DateTime?
  maintenanceStart   DateTime?
  maintenanceEnd     DateTime?
  operator           Operator                @relation(fields: [operatorId], references: [id])
  trips              Trip[]
  maintenances       BusMaintenance[]
  recurringTemplates RecurringTripTemplate[]

  @@unique([operatorId, licensePlate])
}

model BusMaintenance {
  id        String   @id @default(cuid())
  busId     String
  startAt   DateTime
  endAt     DateTime
  reason    String?
  createdAt DateTime @default(now())
  bus       Bus      @relation(fields: [busId], references: [id], onDelete: Cascade)

  @@index([busId])
}

model Route {
  id                 String                  @id @default(cuid())
  origin             String
  destination        String
  operatorId         String
  durationMinutes    Int
  deactivatedAt      DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  /// Issue 044: canonical Place FK (nullable). The free-text origin/destination
  /// columns above stay AS-IS as a back-compat shim; this link is additive.
  originPlaceId      String?
  destPlaceId        String?
  trips              Trip[]
  operator           Operator                @relation(fields: [operatorId], references: [id], onDelete: Restrict)
  originPlace        Place?                  @relation("RouteOrigin", fields: [originPlaceId], references: [id], onDelete: SetNull)
  destPlace          Place?                  @relation("RouteDest", fields: [destPlaceId], references: [id], onDelete: SetNull)
  pickupPoints       PickupPoint[]
  recurringTemplates RecurringTripTemplate[]

  @@index([origin, destination])
  @@index([operatorId])
  @@index([originPlaceId, destPlaceId])
}

/// Issue 044: canonical Place entity — a single global registry of bookable
/// place names with alias merging. GLOBAL (not operator-owned). Routes link to
/// Places via originPlaceId/destPlaceId; free-text Route.origin/destination stay
/// as a back-compat shim.
model Place {
  id            String   @id @default(cuid())
  canonicalName String
  aliases       String[]
  slug          String?  @unique
  createdAt     DateTime @default(now())
  originRoutes  Route[]  @relation("RouteOrigin")
  destRoutes    Route[]  @relation("RouteDest")

  @@index([canonicalName])
}

model PickupPoint {
  id            String    @id @default(cuid())
  routeId       String
  name          String
  address       String
  displayOrder  Int
  deactivatedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  route         Route     @relation(fields: [routeId], references: [id], onDelete: Cascade)
  /// Bookings that have a pickup point assigned (Issue 014)
  bookings      Booking[]

  @@index([routeId, displayOrder])
}

enum TripStatus {
  scheduled
  departed
  completed
  cancelled
}

enum HoldStatus {
  active
  converted
  expired
  cancelled_trip
}

model Trip {
  id                  String                   @id @default(cuid())
  routeId             String
  busId               String
  operatorId          String
  departureAt         DateTime
  price               Int
  status              TripStatus               @default(scheduled)
  salesClosed         Boolean                  @default(false)
  blockedSeats        Int                      @default(0)
  cancelReason        String?
  cancelledAt         DateTime?
  /// Issue 014: timestamp when operator marked trip as departed
  departedAt          DateTime?
  /// Issue 014: timestamp when operator marked trip as completed
  completedAt         DateTime?
  /// FK to RecurringTripTemplate; null for one-off trips
  recurringTemplateId String?
  /// Paired return trip id (self-referential)
  pairedTripId        String?
  updatedAt           DateTime                 @updatedAt
  route               Route                    @relation(fields: [routeId], references: [id])
  bus                 Bus                      @relation(fields: [busId], references: [id])
  operator            Operator                 @relation(fields: [operatorId], references: [id])
  recurringTemplate   RecurringTripTemplate?   @relation(fields: [recurringTemplateId], references: [id])
  pairedTrip          Trip?                    @relation("TripPair", fields: [pairedTripId], references: [id])
  pairedByTrip        Trip[]                   @relation("TripPair")
  holds               Hold[]
  bookings            Booking[]
  generationLogs      RecurringGenerationLog[]
  payouts             Payout[]
  assignedStaff       OperatorUser[]           @relation("StaffAssignment")
  // Partial unique index (recurringTemplateId, departureAt) WHERE recurringTemplateId IS NOT NULL
  // is SQL-only in migration step2; Prisma DSL cannot express WHERE-clause partial unique indices.

  @@index([status, departureAt])
  @@index([routeId, departureAt])
  @@index([operatorId])
  @@index([recurringTemplateId])
  @@index([pairedTripId])
}

model Hold {
  id            String     @id @default(cuid())
  tripId        String
  ticketCount   Int
  customerPhone String
  customerName  String
  /// Issue 042: buyer email captured at hold creation (S03/S04 guest snapshot = name+phone+email). Nullable for pre-042 rows.
  customerEmail String?
  expiresAt     DateTime
  status        HoldStatus @default(active)
  createdAt     DateTime   @default(now())
  trip          Trip       @relation(fields: [tripId], references: [id])
  booking       Booking?

  @@index([tripId, status, expiresAt])
  @@index([expiresAt])
}

enum BookingStatus {
  awaiting_payment
  pending_cash_payment
  paid_operator_notified
  completed
  cancelled
  trip_cancelled
  no_show
  payment_failed_expired
}

/// Contact status for operator call-queue management (Issue 014).
enum ContactStatus {
  pending
  reached
  no_answer
  callback
}

enum PaymentMethod {
  cash
  momo
  zalopay
  card
}

enum NotificationChannel {
  sms
}

enum NotificationStatus {
  pending
  sent
  failed
}

model Booking {
  id                 String            @id @db.Uuid
  bookingRef         String            @unique
  confirmationToken  String            @unique
  tripId             String
  holdId             String?           @unique
  customerId         String?
  buyerName          String
  buyerPhone         String
  /// Issue 042: buyer email for ticket delivery (S03/S04 guest snapshot = name+phone+email). Nullable — pre-042 rows have no email.
  buyerEmail         String?
  ticketCount        Int
  totalVnd           Int
  paymentMethod      PaymentMethod
  paymentExternalRef String?
  status             BookingStatus     @default(awaiting_payment)
  isManual           Boolean           @default(false)
  createdAt          DateTime          @default(now())
  /// Issue 014: operator call-queue contact tracking
  contactStatus      ContactStatus     @default(pending)
  /// Pickup point assigned during call-outcome (FK → PickupPoint; null = use route default)
  pickupPointId      String?
  /// Free-text pickup note when no configured pickup points exist
  pickupNote         String?
  /// Timestamp when boarding was marked (SET-TRUE-ONLY per SPEC NOTE)
  pickedUpAt         DateTime?
  /// Timestamp when cash was collected by operator
  cashCollectedAt    DateTime?
  /// Escalation note set by operator
  escalationNote     String?
  /// Timestamp of escalation
  escalatedAt        DateTime?
  /// Issue 019: timestamp the 24h SMS reminder was sent (null = not yet sent; sweeper predicate)
  reminderSentAt     DateTime?
  trip               Trip              @relation(fields: [tripId], references: [id])
  hold               Hold?             @relation(fields: [holdId], references: [id], onDelete: Restrict)
  customer           Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  pickupPoint        PickupPoint?      @relation(fields: [pickupPointId], references: [id], onDelete: SetNull)
  notifications      NotificationLog[]
  paymentEvents      PaymentEvent[]
  ledgerEntries      LedgerEntry[]

  @@index([tripId, status])
  @@index([confirmationToken])
  @@index([customerId])
  @@index([tripId, contactStatus])
  @@index([tripId, pickedUpAt])
  @@index([status, reminderSentAt])
  /// Issue 009: register-time guest-booking backfill scan (match buyerPhone → Customer.phone)
  @@index([buyerPhone])
}

model PaymentEvent {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId     String   @db.Uuid
  adapter       String
  providerTxnId String
  currency      String   @default("VND")
  rawBody       String   @db.Text
  receivedAt    DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])

  @@unique([adapter, providerTxnId])
  @@index([bookingId])
}

model NotificationLog {
  id           String              @id @default(cuid())
  bookingId    String?             @db.Uuid
  channel      NotificationChannel @default(sms)
  template     String
  recipient    String
  payload      String
  status       NotificationStatus  @default(pending)
  externalRef  String?
  sentAt       DateTime?
  scheduledFor DateTime? // S19 cron: payout_scheduled dispatch time (completedAt+3d)
  createdAt    DateTime            @default(now())
  booking      Booking?            @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([template, scheduledFor])
}

/// Issue 019: one row per cron-job invocation. status ∈ success|failed|skipped_locked.
model JobRunLog {
  id           String    @id @default(cuid())
  jobName      String
  startedAt    DateTime
  endedAt      DateTime?
  status       String
  rowsAffected Int       @default(0)
  errorMessage String?
  createdAt    DateTime  @default(now())

  @@index([jobName, startedAt])
}

model Customer {
  id           String    @id @default(cuid())
  /// Nullable: set to NULL on soft-delete/anonymization; Postgres allows multiple NULLs on @unique
  phone        String?   @unique
  email        String?
  passwordHash String?
  displayName  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLoginAt  DateTime?
  /// Issue 008: soft-delete timestamp; non-null = account deleted
  deletedAt    DateTime?
  /// Issue 008: anonymization timestamp; set together with deletedAt
  anonymizedAt DateTime?
  sessions     Session[]
  bookings     Booking[]
}

model OtpAttempt {
  id           String    @id @default(cuid())
  phone        String
  codeHash     String
  salt         String
  expiresAt    DateTime
  consumed     Boolean   @default(false)
  consumedAt   DateTime?
  attemptCount Int       @default(0)
  createdAt    DateTime  @default(now())
  ipAddress    String?

  @@index([phone, createdAt(sort: Desc)])
}

model Session {
  id               String    @id @default(cuid())
  customerId       String
  refreshTokenHash String    @unique
  tokenFamily      String
  rotationCount    Int       @default(0)
  expiresAt        DateTime
  createdAt        DateTime  @default(now())
  revokedAt        DateTime?
  customer         Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

// ---------------------------------------------------------------------------
// Issue 010 — Operator auth models
// ---------------------------------------------------------------------------

enum OperatorRole {
  admin
  staff
}

model OperatorUser {
  id                     String            @id @default(cuid())
  operatorId             String
  phone                  String            @unique
  contactPhone           String
  notificationPhone      String
  passwordHash           String
  requiresPasswordChange Boolean           @default(true)
  displayName            String
  role                   OperatorRole      @default(admin)
  disabledAt             DateTime?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  /// Issue 014: badge — last time operator viewed the bookings queue
  lastBookingsViewedAt   DateTime?
  /// Issue 017: single trip a staff member is assigned to (V1 constraint); null for admins
  assignedTripId         String?
  operator               Operator          @relation(fields: [operatorId], references: [id])
  assignedTrip           Trip?             @relation("StaffAssignment", fields: [assignedTripId], references: [id])
  sessions               OperatorSession[]

  @@index([createdAt])
  @@index([operatorId])
  @@index([assignedTripId])
}

model OperatorSession {
  id               String       @id @default(cuid())
  operatorUserId   String
  refreshTokenHash String       @unique
  tokenFamily      String
  rotationCount    Int          @default(0)
  expiresAt        DateTime
  createdAt        DateTime     @default(now())
  revokedAt        DateTime?
  operator         OperatorUser @relation(fields: [operatorUserId], references: [id], onDelete: Cascade)

  @@index([operatorUserId])
}

model OperatorOtpAttempt {
  id           String    @id @default(cuid())
  phone        String
  codeHash     String
  salt         String
  expiresAt    DateTime
  consumed     Boolean   @default(false)
  consumedAt   DateTime?
  attemptCount Int       @default(0)
  createdAt    DateTime  @default(now())
  ipAddress    String?

  @@index([phone, createdAt(sort: Desc)])
}

// ---------------------------------------------------------------------------
// Issue 016 — Operator revenue reporting + payout tracking
// ---------------------------------------------------------------------------

enum PayoutStatus {
  pending
  processing
  settled
  failed
}

model Payout {
  id            String       @id @default(cuid())
  tripId        String
  operatorId    String
  gross         Int
  platformFee   Int
  net           Int
  status        PayoutStatus @default(pending)
  scheduledAt   DateTime
  settledAt     DateTime?
  failureReason String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  trip          Trip         @relation(fields: [tripId], references: [id])
  operator      Operator     @relation(fields: [operatorId], references: [id])

  @@index([tripId])
  @@index([status, scheduledAt])
  @@index([operatorId, status])
}

// ---------------------------------------------------------------------------
// Issue 013 — Operator trip lifecycle models
// ---------------------------------------------------------------------------

/// Recurring trip schedule template. Generates Trips daily via cron (14-day horizon).
model RecurringTripTemplate {
  id                 String                   @id @default(cuid())
  operatorId         String
  routeId            String
  busId              String
  price              Int
  /// HH:MM local time (Asia/Ho_Chi_Minh)
  departureLocalTime String
  /// Bitmask: Mon=1, Tue=2, Wed=4, Thu=8, Fri=16, Sat=32, Sun=64 (range 1-127)
  daysOfMask         Int
  validFrom          DateTime                 @db.Date
  validUntil         DateTime                 @db.Date
  deactivatedAt      DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  operator           Operator                 @relation(fields: [operatorId], references: [id])
  route              Route                    @relation(fields: [routeId], references: [id])
  bus                Bus                      @relation(fields: [busId], references: [id])
  trips              Trip[]
  generationLogs     RecurringGenerationLog[]

  @@index([operatorId])
  @@index([routeId])
  @@index([busId])
}

/// Log of each daily cron run's result per template per date.
model RecurringGenerationLog {
  id         String                @id @default(cuid())
  templateId String
  tripId     String?
  /// Date being generated (YYYY-MM-DD key)
  date       DateTime              @db.Date
  /// 'generated' | 'skipped' | 'failed'
  status     String                @default("generated")
  skipReason String?
  createdAt  DateTime              @default(now())
  template   RecurringTripTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  trip       Trip?                 @relation(fields: [tripId], references: [id], onDelete: SetNull)

  @@index([templateId])
  @@index([date])
}

// ---------------------------------------------------------------------------
// Issue 020 — Platform-admin CLI audit trail
// ---------------------------------------------------------------------------

/// Append-only audit log for platform-admin CLI write actions.
/// `actor` is a plain string (OS user / jumpbox identity), not an FK — the CLI
/// runs outside the app's auth context. `argsRedacted` stores the command args
/// with phone numbers masked to last-4 (see lib/audit/redactPhone.ts).
model AdminAuditLog {
  id           String   @id @default(cuid())
  actor        String
  action       String
  target       String
  argsRedacted String?
  timestamp    DateTime @default(now())

  @@index([timestamp])
  @@index([action, timestamp])
}

// ---------------------------------------------------------------------------
// Conversion-funnel instrumentation
// ---------------------------------------------------------------------------

/// Append-only anonymous funnel event. `sessionId` is a random cookie value (no
/// PII), `step` is one of search_performed | hold_created | payment_initiated |
/// booking_paid. Written fire-and-forget — never blocks the request path.
model FunnelEvent {
  id        String   @id @default(cuid())
  sessionId String
  step      String
  tripId    String?
  bookingId String?
  context   Json?
  createdAt DateTime @default(now())

  @@index([step, createdAt])
  @@index([sessionId])
}

// ---------------------------------------------------------------------------
// Issue 047 — Append-only double-entry ledger (money one-way door)
// ---------------------------------------------------------------------------

enum LedgerEntryType {
  booking_credit
  platform_fee
  refund_debit
  refund_out
  payout_debit
  payout_reversal
  chargeback
  adjustment
}

/// Issue 047: append-only, immutable money ledger. One row per money event.
///
/// IMMUTABILITY: enforced at the DB by a BEFORE UPDATE/DELETE trigger
/// (`ledger_entry_immutable`) — NOT by a role REVOKE — so it holds regardless of
/// the connecting DB role (e.g. Neon pooled role). The trigger is SQL-only; the
/// Prisma DSL cannot model triggers, so it never appears here and is invisible to
/// `prisma migrate diff` (schema↔DB parity caveat, like partial indices in Issue 007).
///
/// SIGN CONVENTION (documented in lib/ledger/ledgerRepo.ts; NOT DB-enforced in
/// this slice): positive = credit TO operator balance, negative = debit FROM it.
/// `amount` is signed minor units (VND, integer) stored as BIGINT.
///
/// `payoutId` is a plain column (NO FK) — kept decoupled from the Payout model in
/// this slice; wiring + referential integrity land in slices 049/050.
model LedgerEntry {
  id            String          @id @default(cuid())
  operatorId    String
  bookingId     String?         @db.Uuid
  payoutId      String?
  type          LedgerEntryType
  amount        BigInt // signed minor units (VND); sign convention in repo header
  currency      String          @default("VND")
  /// Idempotency key: unique per (type, source). Duplicate appends are no-ops.
  sourceEventId String
  createdAt     DateTime        @default(now())

  operator Operator @relation(fields: [operatorId], references: [id])
  booking  Booking? @relation(fields: [bookingId], references: [id])

  @@unique([sourceEventId])
  @@index([operatorId])
  @@index([bookingId])
  @@index([payoutId])
}

/// FeeConfig (Issue 048) — effective-dated, change-audited platform-fee source.
///
/// The platform fee rate is stored as `ratePpm`, a parts-per-million INTEGER
/// (60000 = 6%), so callers can compute `amount * ratePpm / 1_000_000` entirely
/// in the BigInt domain with no float drift (Issue 016). Slice 049 cuts the
/// hard-coded DEFAULT_PLATFORM_FEE_PCT over to read from here.
///
/// EFFECTIVE-DATED + APPEND-AUDITED: a rate change is a NEW row (optionally
/// closing the prior row's effectiveTo), NEVER an in-place edit of an existing
/// row's ratePpm. This preserves the full historical rate timeline for audit
/// and lets payout math resolve the rate that was in force at any past instant.
///
/// SCOPING: operatorId NULL = global default rate; non-null = per-operator
/// override. Resolution is override-then-global (see lib/ledger/feeConfig.ts).
model FeeConfig {
  id            String    @id @default(cuid())
  operatorId    String? // NULL = global default; non-null = per-operator override
  ratePpm       Int // fee rate in parts-per-million (60000 = 6%)
  effectiveFrom DateTime
  effectiveTo   DateTime? // NULL = open-ended (current)
  createdBy     String? // admin/actor id; nullable for the seeded cutover row
  createdAt     DateTime  @default(now())

  operator Operator? @relation(fields: [operatorId], references: [id])

  @@index([operatorId, effectiveFrom])
  @@index([effectiveFrom])
}
