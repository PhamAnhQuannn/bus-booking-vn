generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model Operator {
  id                String    @id @default(cuid())
  legalName         String
  contactPhone      String
  contactEmail      String
  notificationPhone String?
  disabledAt        DateTime?
  createdAt         DateTime  @default(now())
  buses             Bus[]

  @@index([id])
}

model Bus {
  id               String    @id @default(cuid())
  operatorId       String
  capacity         Int
  plateNumber      String    @unique
  maintenanceStart DateTime?
  maintenanceEnd   DateTime?
  operator         Operator  @relation(fields: [operatorId], references: [id])
  trips            Trip[]

  @@index([operatorId])
}

model Route {
  id          String   @id @default(cuid())
  origin      String
  destination String
  createdAt   DateTime @default(now())
  trips       Trip[]

  @@index([origin, destination])
}

enum TripStatus {
  scheduled
  departed
  completed
  cancelled
}

enum HoldStatus {
  active
  converted
  expired
  cancelled_trip
}

model Trip {
  id           String     @id @default(cuid())
  routeId      String
  busId        String
  departureAt  DateTime
  price        Int
  status       TripStatus @default(scheduled)
  salesClosed  Boolean    @default(false)
  blockedSeats Int        @default(0)
  route        Route      @relation(fields: [routeId], references: [id])
  bus          Bus        @relation(fields: [busId], references: [id])
  holds        Hold[]
  bookings     Booking[]

  @@index([status, departureAt])
  @@index([routeId, departureAt])
}

model Hold {
  id            String     @id @default(cuid())
  tripId        String
  ticketCount   Int
  customerPhone String
  customerName  String
  expiresAt     DateTime
  status        HoldStatus @default(active)
  createdAt     DateTime   @default(now())
  trip          Trip       @relation(fields: [tripId], references: [id])
  booking       Booking?

  @@index([tripId, status, expiresAt])
  @@index([expiresAt])
}

enum BookingStatus {
  awaiting_payment
  pending_cash_payment
  paid_operator_notified
  completed
  cancelled
  trip_cancelled
  no_show
  payment_failed_expired
}

enum PaymentMethod {
  cash
  momo
  zalopay
  card
}

enum NotificationChannel {
  sms
}

enum NotificationStatus {
  pending
  sent
  failed
}

model Booking {
  id                 String        @id @db.Uuid
  bookingRef         String        @unique
  confirmationToken  String        @unique
  tripId             String
  holdId             String?       @unique
  buyerName          String
  buyerPhone         String
  ticketCount        Int
  totalVnd           Int
  paymentMethod      PaymentMethod
  paymentExternalRef String?
  status             BookingStatus @default(awaiting_payment)
  isManual           Boolean       @default(false)
  createdAt          DateTime      @default(now())
  trip               Trip          @relation(fields: [tripId], references: [id])
  hold               Hold?         @relation(fields: [holdId], references: [id], onDelete: Restrict)
  notifications      NotificationLog[]
  paymentEvents      PaymentEvent[]

  @@index([tripId, status])
  @@index([confirmationToken])
}

model PaymentEvent {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId   String   @db.Uuid
  adapter     String
  externalRef String
  rawBody     String   @db.Text
  resultCode  Int
  receivedAt  DateTime @default(now())

  booking     Booking  @relation(fields: [bookingId], references: [id])

  @@unique([adapter, externalRef])
  @@index([bookingId])
}

model NotificationLog {
  id          String              @id @default(cuid())
  bookingId   String              @db.Uuid
  channel     NotificationChannel @default(sms)
  template    String
  recipient   String
  payload     String
  status      NotificationStatus  @default(pending)
  externalRef String?
  sentAt      DateTime?
  createdAt   DateTime            @default(now())
  booking     Booking             @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}
