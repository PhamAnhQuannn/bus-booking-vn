{
  "name": "bus-booking",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts --reporter=verbose",
    "vitest:int": "vitest run --config vitest.integration.config.ts",
    "test:all": "vitest run && vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "admin:create-operator": "tsx --env-file=.env.production scripts/admin/createOperator.ts",
    "admin:disable-operator": "tsx --env-file=.env.production scripts/admin/disableOperator.ts",
    "admin:reset-operator-admin-password": "tsx --env-file=.env.production scripts/admin/resetOperatorAdminPassword.ts",
    "admin:list-operators": "tsx --env-file=.env.production scripts/admin/listOperators.ts",
    "admin:bootstrap-super-admin": "tsx --env-file=.env.production scripts/admin/bootstrapSuperAdmin.ts",
    "admin:reset-admin-totp": "tsx --env-file=.env.production scripts/admin/resetAdminTotpBreakGlass.ts",
    "seed:trips": "tsx --env-file=.env.local scripts/seed/seed-trips-range.ts",
    "seed:operator": "tsx --env-file=.env.local scripts/seed/seed-operator.ts",
    "seed:admin": "tsx --env-file=.env.local scripts/seed/seed-admin.ts",
    "admin:code": "tsx --env-file=.env.local scripts/seed/admin-totp-code.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@react-pdf/renderer": "^4.5.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "pino": "^10.3.1",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.4",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "uuidv7": "^1.2.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-import-x": "^4.16.2",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "pg": "^8.20.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.1",
    "typescript": "^5",
    "vitest": "^4.1.6"
  },
  "pnpm": {
    "overrides": {
      "@hono/node-server": ">=1.19.13",
      "postcss": ">=8.5.10"
    }
  }
}
