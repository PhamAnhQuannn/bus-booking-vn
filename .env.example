# Local development — docker-compose.dev.yml + pnpm dev (port 3001)
# Copy this file to .env.local and fill in values
DATABASE_URL="postgresql://bbvn:bbvn_dev_password@localhost:5432/bbvn_dev"
# DIRECT_URL: bypass connection pooler (Neon built-in or PgBouncer) for migrations.
# In local dev, set to same value as DATABASE_URL (no pooler).
DIRECT_URL="postgresql://bbvn:bbvn_dev_password@localhost:5432/bbvn_dev"
SHADOW_DATABASE_URL="postgresql://bbvn:bbvn_dev_password@localhost:5434/bbvn_shadow"

# Production rate-limiting via Upstash Redis
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Issue 002: Hold / seat-block feature
# HOLD_SECRET: min 32 bytes of hex — used to sign bb_hold cookies (HMAC-SHA256)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HOLD_SECRET="replace-with-32-byte-hex"

# HOLD_SWEEPER_MODE: "count" (log only) | "update" (mark expired holds in DB)
# Default is "update" — expired holds release capacity. Set to "count" for dry-run canary.
HOLD_SWEEPER_MODE="update"

# CRON_SECRET: Vercel injects this as Bearer <secret> on Authorization header for cron routes.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Set in Vercel project settings under Environment Variables > CRON_SECRET.
# In local dev, leave unset — cron routes are open without auth when the variable is absent.
CRON_SECRET="replace-with-random-hex"

# SEARCH_USE_BLOCKED_SEATS: "false" | "true"
# Flip to "true" after Steps 7+9 ship to subtract active-hold seats from search results.
SEARCH_USE_BLOCKED_SEATS="false"

# Issue 126: SePay / VietQR bank transfer (Phase 1 primary payment method)
# SEPAY_API_KEY: Bearer token for webhook authentication.
# Required when PAYMENTS_STUB=false. Generate with SePay dashboard.
# SEPAY_API_KEY=""
# VietQR image generation — Agribank defaults below.
VIETQR_BANK_BIN="970405"
VIETQR_ACCOUNT_NUMBER="3516205005863"
VIETQR_ACCOUNT_NAME="BUS BOOK VN"
VIETQR_TEMPLATE="compact2"

# Issue 004: MoMo payment gateway
# Defaults below are MoMo sandbox credentials (vendor-published). Override for production.
MOMO_PARTNER_CODE="MOMOBKUN20180529"
MOMO_ACCESS_KEY="klm05TvNBzhg7h7j"
# NEVER commit real MOMO_SECRET_KEY to version control.
MOMO_SECRET_KEY="at67qH6mk8w5Y1nAyMoYKMWACiEi2bsa"
MOMO_ENDPOINT="https://test-payment.momo.vn/v2/gateway/api/create"

# Issue 077: VNPay payment gateway
# Defaults below are VNPay sandbox credentials. Override for production.
VNPAY_TMN_CODE="VNPAYTEST"
VNPAY_HASH_SECRET="VNPAYSECRETTEST0123456789ABCDEF01"
VNPAY_URL="https://sandbox.vnpayment.vn/paymentv2/vpcpay.html"
VNPAY_RETURN_URL="http://localhost:3001/api/payments/vnpay/return"

# Issue 007: Customer OTP auth + AuthModule
# JWT_SECRET: min 32 bytes of hex — used to sign access tokens (HS256, 15min exp)
# REFRESH_TOKEN_SECRET: min 32 bytes of hex — used to HMAC-SHA256 refresh tokens
# Generate each with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="replace-with-32-byte-hex"
JWT_OPERATOR_SECRET="replace-with-32-byte-hex"
JWT_ADMIN_SECRET="replace-with-32-byte-hex"
REFRESH_TOKEN_SECRET="replace-with-32-byte-hex"
# TOTP_ENCRYPTION_KEY: 64 hex chars (32 bytes) for AES-256-GCM encryption of admin TOTP secrets.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOTP_ENCRYPTION_KEY="replace-with-64-hex-chars"
# BANK_ENCRYPTION_KEY: 64 hex chars (32 bytes) for AES-256-GCM encryption of PayoutAccount.accountNumber.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BANK_ENCRYPTION_KEY="replace-with-64-hex-chars"

# E2E_DATA_LEAK_ENABLED: gates the data-leak smoke E2E spec (e2e/data-leak-smoke.spec.ts).
# Set to "true" only in local dev or CI with a disposable DB + running dev server.
# E2E_DATA_LEAK_ENABLED=true

# OTP_PEEK_ENABLED: enables GET /api/auth/otp/test-peek for E2E tests.
# MUST NOT be set (or must be absent / "false") in any production or staging deployment.
# Only set to "true" in local dev and CI test environments alongside NODE_ENV != production.
# OTP_PEEK_ENABLED=true

# Issue 015: Manual booking kill-switch.
# Default-on: when absent (or any value other than "false") the endpoint is enabled.
# Set to "false" to disable POST /api/op/trips/[id]/manual-booking → 503 feature_disabled.
# MANUAL_BOOKING_ENABLED=false

# Issue 059: object storage (signed PUT/GET, keys in DB).
# STORAGE_STUB default-on ("true"): server mints HMAC-signed stub PUT/GET URLs
# against /dev/stub-storage; no real S3 / @aws-sdk needed. Flip to "false" only
# once the Wave-9 real-S3 adapter lands (until then the real branch throws).
STORAGE_STUB="true"
# STORAGE_STUB_SECRET: min 16 chars — HMAC key signing stub URLs (tamper-evident).
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
STORAGE_STUB_SECRET="replace-with-random-secret-min-16-chars"
# Real-S3 connection vars (only consulted when STORAGE_STUB=false — leave unset in stub mode):
# STORAGE_BUCKET=""
# STORAGE_REGION=""
# STORAGE_ENDPOINT=""
# STORAGE_ACCESS_KEY=""
# STORAGE_SECRET_KEY=""

# Issue 058 + SMS-OTP: notification channels.
# NOTIFY_STUB default-on ("true"): SMS/email are logged, never sent (OTP test
# sink stays usable). Flip to "false" to send real SMS via eSMS.vn — then the
# three ESMS_* creds below are REQUIRED (boot fails fast without them).
NOTIFY_STUB="true"
# eSMS.vn (real SMS — only consulted when NOTIFY_STUB=false). Register a Brandname
# (needs a VN business license + telco OTP-template approval, ~5-10 business days).
# NEVER commit real ESMS_SECRET_KEY. Keep ESMS_SANDBOX="true" until go-live.
# ESMS_API_KEY=""
# ESMS_SECRET_KEY=""
# ESMS_BRANDNAME=""
# ESMS_OTP_SMSTYPE="2"
# ESMS_SANDBOX="true"
# ESMS_BASE_URL="https://rest.esms.vn"

# Issue 074: E-invoice (hóa đơn điện tử) — Circular 78/2021.
# EINVOICE_ENABLED: "stub" (default, log only) | "misa" (real MISA meInvoice API).
EINVOICE_ENABLED="stub"
# MISA credentials (only consulted when EINVOICE_ENABLED=misa):
# MISA_API_URL=""
# MISA_API_KEY=""
# MISA_COMPANY_CODE=""
# MISA_TEMPLATE_CODE=""

# Issue 080: Transactional email via Resend.
# EMAIL_PROVIDER: "stub" (default, NOTIFY_STUB covers) | "resend" (real Resend API).
# EMAIL_PROVIDER="resend"
# RESEND_API_KEY=""
# EMAIL_FROM="noreply@busbookvn.com"

# Issue 083: Self-hosted Redis (ioredis).
# REDIS_PROVIDER: unset/memory (default) | "ioredis" (self-hosted) | "upstash" (Vercel).
# REDIS_PROVIDER="ioredis"
# REDIS_URL="redis://localhost:6379"

# Connection pooler direct URL for migrations (production only).
# On Vercel: Neon provides pooled (DATABASE_URL) + unpooled (DIRECT_URL) connection strings.
# On Docker self-hosted: PgBouncer :6432 (DATABASE_URL) + direct :5432 (DIRECT_URL).
# In local dev: both point to localhost:5432 (no pooler needed).
# DIRECT_URL="postgresql://bbvn:password@localhost:5432/bbvn"

# -----------------------------------------------------------------------------
# Public site origin — drives metadataBase, robots.txt, sitemap.xml, and the
# absolute URLs in JSON-LD structured data. Set the REAL production domain at
# deploy (no trailing slash). Omitted in dev → falls back to http://localhost:3001.
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SITE_URL="https://bbvn.example"

# -----------------------------------------------------------------------------
# TEMP (dev/test): disable the admin login TOTP (6-digit code) step.
# When "true" AND NODE_ENV != production, admin login = email+password only and
# the session is minted totpVerified=true (code screen skipped). HARD-GUARDED:
# ignored in production no matter what (see lib/auth/totpDisabled.ts).
# Re-enable normal 2-step TOTP: set "false" or remove this line + restart.
# -----------------------------------------------------------------------------
# ADMIN_TOTP_DISABLED="false"
