# Copy this file to .env.local and fill in values
DATABASE_URL="postgresql://bbvn:bbvn_dev_password@localhost:5432/bbvn_dev"
SHADOW_DATABASE_URL="postgresql://bbvn:bbvn_dev_password@localhost:5434/bbvn_shadow"

# Production rate-limiting via Upstash Redis
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Issue 002: Hold / seat-block feature
# HOLD_SECRET: min 32 bytes of hex — used to sign bb_hold cookies (HMAC-SHA256)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HOLD_SECRET="replace-with-32-byte-hex"

# HOLD_SWEEPER_MODE: "count" (log only) | "update" (mark expired holds in DB)
# Flip to "update" after canary confirms cron is healthy.
HOLD_SWEEPER_MODE="count"

# CRON_SECRET: Vercel injects this as Bearer <secret> on Authorization header for cron routes.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Set in Vercel project settings under Environment Variables > CRON_SECRET.
# In local dev, leave unset — cron routes are open without auth when the variable is absent.
CRON_SECRET="replace-with-random-hex"

# SEARCH_USE_BLOCKED_SEATS: "false" | "true"
# Flip to "true" after Steps 7+9 ship to subtract active-hold seats from search results.
SEARCH_USE_BLOCKED_SEATS="false"

# Issue 004: MoMo payment gateway
# Defaults below are MoMo sandbox credentials (vendor-published). Override for production.
MOMO_PARTNER_CODE="MOMOBKUN20180529"
MOMO_ACCESS_KEY="klm05TvNBzhg7h7j"
# NEVER commit real MOMO_SECRET_KEY to version control.
MOMO_SECRET_KEY="at67qH6mk8w5Y1nAyMoYKMWACiEi2bsa"
MOMO_ENDPOINT="https://test-payment.momo.vn/v2/gateway/api/create"

# Issue 007: Customer OTP auth + AuthModule
# JWT_SECRET: min 32 bytes of hex — used to sign access tokens (HS256, 15min exp)
# REFRESH_TOKEN_SECRET: min 32 bytes of hex — used to HMAC-SHA256 refresh tokens
# Generate each with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="replace-with-32-byte-hex"
REFRESH_TOKEN_SECRET="replace-with-32-byte-hex"

# OTP_PEEK_ENABLED: enables GET /api/auth/otp/test-peek for E2E tests.
# MUST NOT be set (or must be absent / "false") in any production or staging deployment.
# Only set to "true" in local dev and CI test environments alongside NODE_ENV != production.
# OTP_PEEK_ENABLED=true

# Issue 015: Manual booking kill-switch.
# Default-on: when absent (or any value other than "false") the endpoint is enabled.
# Set to "false" to disable POST /api/op/trips/[id]/manual-booking → 503 feature_disabled.
# MANUAL_BOOKING_ENABLED=false

# Issue 059: object storage (signed PUT/GET, keys in DB).
# STORAGE_STUB default-on ("true"): server mints HMAC-signed stub PUT/GET URLs
# against /dev/stub-storage; no real S3 / @aws-sdk needed. Flip to "false" only
# once the Wave-9 real-S3 adapter lands (until then the real branch throws).
STORAGE_STUB="true"
# STORAGE_STUB_SECRET: min 16 chars — HMAC key signing stub URLs (tamper-evident).
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
STORAGE_STUB_SECRET="replace-with-random-secret-min-16-chars"
# Real-S3 connection vars (only consulted when STORAGE_STUB=false — leave unset in stub mode):
# STORAGE_BUCKET=""
# STORAGE_REGION=""
# STORAGE_ENDPOINT=""
# STORAGE_ACCESS_KEY=""
# STORAGE_SECRET_KEY=""

# Issue 058 + SMS-OTP: notification channels.
# NOTIFY_STUB default-on ("true"): SMS/email are logged, never sent (OTP test
# sink stays usable). Flip to "false" to send real SMS via eSMS.vn — then the
# three ESMS_* creds below are REQUIRED (boot fails fast without them).
NOTIFY_STUB="true"
# eSMS.vn (real SMS — only consulted when NOTIFY_STUB=false). Register a Brandname
# (needs a VN business license + telco OTP-template approval, ~5-10 business days).
# NEVER commit real ESMS_SECRET_KEY. Keep ESMS_SANDBOX="true" until go-live.
# ESMS_API_KEY=""
# ESMS_SECRET_KEY=""
# ESMS_BRANDNAME=""
# ESMS_OTP_SMSTYPE="2"
# ESMS_SANDBOX="true"
# ESMS_BASE_URL="https://rest.esms.vn"
